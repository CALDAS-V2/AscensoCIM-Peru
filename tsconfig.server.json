{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "skipDefaultLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/server.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.tsx", "src/pages", "src/lib/blink.ts", "src/lib/supabase.ts", "src/lib/useAuth.ts"]
}
