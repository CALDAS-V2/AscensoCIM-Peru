{
  "name": "vite-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "node dist/server.js",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:db-push": "prisma db push",
    "migrate:prod": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "lint:css": "stylelint \"src/**/*.css\" --fix --quiet",
    "lint:js": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:types": "tsc --noEmit",
    "check:css-vars": "node scripts/check-css-variables.js",
    "check:css-classes": "node scripts/check-css-classes.js",
    "lint": "bun run lint:types && bun run lint:js && bun run lint:css && bun run check:css-vars && bun run check:css-classes"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/react-google-recaptcha": "^2.1.9",
    "concurrently": "^8.2.2",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "@blinkdotnew/sdk": "^2.5.0",
    "@blinkdotnew/ui": "^0.5.2",
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.7.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "5.2.0",
    "argon2": "^0.44.0",
    "autoprefixer": "10.4.16",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "nodemailer": "^8.0.11",
    "postcss": "8.4.31",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-responsive": "^10.0.1",
    "recharts": "^3.8.1",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3.3.5",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  }
}
